# Cal.com – booking URLs for "Citas y visitas" (two appointment types).
# Get these from your Cal.com dashboard: Event Types → [event] → Copy link.
# If set, the booking dialog will embed Cal.com; otherwise the fallback form is used.
NEXT_PUBLIC_CAL_COM_VISITA_ONLINE=https://cal.com/your-username/visita-online
NEXT_PUBLIC_CAL_COM_VISITA_OFICINA=https://cal.com/your-username/visita-oficina

# Optional: hero section video (e.g. YouTube ID)
# NEXT_PUBLIC_HERO_VIDEO_ID=

# Supabase – required for auth and data.
# Create a project at supabase.com, then copy from Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Base URL for email confirmation links (auth callback).
# Use your production URL when deployed.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
